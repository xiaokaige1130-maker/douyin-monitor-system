# Database
DATABASE_URL=postgresql+asyncpg://douyin:douyin123@localhost:5432/douyin_monitor
REDIS_URL=redis://localhost:6379/0

# InfluxDB / Grafana
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=douyin-token-123
INFLUXDB_ORG=douyin
INFLUXDB_BUCKET=douyin_data

# Douyin session. Fill this only with an account you are allowed to use.
DOUYIN_COOKIE=
DOUYIN_TOKEN=

# Monitor frequency. Keep low frequency to reduce account risk.
CHECK_INTERVAL_NORMAL=10
CHECK_INTERVAL_LIVE=2
MAX_CONCURRENT_CHECKS=3
MIN_REQUEST_DELAY_SECONDS=2
MAX_REQUEST_DELAY_SECONDS=8
FAILURE_COOLDOWN_THRESHOLD=3
ACCOUNT_COOLDOWN_MINUTES=30
RISK_COOLDOWN_MINUTES=180

# Optional outbound proxy. Do not use this to bypass platform restrictions.
PROXY_ENABLED=false
PROXY_URL=

# API
API_ENABLED=true
API_HOST=0.0.0.0
API_PORT=8000

# Browser/request
HEADLESS_BROWSER=true
BROWSER_TIMEOUT=30
REQUEST_TIMEOUT=30
MAX_RETRIES=2
RETRY_DELAY=5

# Notifications
NOTIFICATION_ENABLED=true
DINGTALK_WEBHOOK=
WECHAT_WEBHOOK=
EMAIL_SMTP_SERVER=
EMAIL_SMTP_PORT=587
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_RECIPIENTS=

LOG_LEVEL=INFO
DATA_RETENTION_DAYS=30
